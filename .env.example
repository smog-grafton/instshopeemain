# Site Configuration (buyer frontend domain)
NEXT_PUBLIC_SITE_URL=https://instshopee.com.my

# Laravel API URL (must include /api suffix). Use a host that serves Laravel, not the Next.js storefront.
NEXT_PUBLIC_LARAVEL_API_URL=https://api.instshopee.com.my/api

# Server-only: when Next and Laravel are on different URLs, set this so SSR (e.g. /m/welcome-perks) hits Laravel.
# Omit if NEXT_PUBLIC_LARAVEL_API_URL already points at Laravel from the Node server.
# LARAVEL_API_URL=https://your-laravel-host.example.com/api

# Seller Centre URL used by top navbar "Seller Centre" link
NEXT_PUBLIC_SELLER_CENTRE_URL=https://seller.instshopee.com.my

# Domain-to-country mapping JSON for middleware/server context
# Include both buyer and seller hosts you serve.
# Example:
# NEXT_PUBLIC_DOMAIN_COUNTRY_MAP={"instshopee.com.my":"MY","seller.instshopee.com.my":"MY","instshopee.co.id":"ID","seller.instshopee.co.id":"ID"}
NEXT_PUBLIC_DOMAIN_COUNTRY_MAP={}

# Google Maps Configuration
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Environment
NODE_ENV=development
